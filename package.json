{
  "name": "comfy-bridge-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight local ComfyUI sidecar for OpenClaw / IM async task orchestration.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test",
    "test:coverage": "node --import tsx --test --experimental-test-coverage",
    "openapi:build": "node --import tsx src/openapi.ts > openapi.json",
    "openapi:types": "openapi-typescript openapi.json -o src/generated/api-types.ts",
    "postinstall": "typesync && npm install --package-lock-only"
  },
  "dependencies": {
    "@fastify/swagger": "latest",
    "@fastify/swagger-ui": "latest",
    "@fastify/type-provider-typebox": "latest",
    "@sinclair/typebox": "latest",
    "better-sqlite3": "latest",
    "fastify": "latest",
    "ws": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "latest",
    "@types/ws": "^8.18.1",
    "openapi-typescript": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typesync": "^0.14.3",
    "undici": "latest"
  }
}
